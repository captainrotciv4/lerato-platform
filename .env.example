# ════════════════════════════════════════════════════════════════════
# Lerato Platform — Environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev: postgresql://postgres:postgres@localhost:5432/lerato_dev
# Production: provided by Railway / Render / Supabase
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lerato_dev"

# ─── Authentication (Auth.js v5) ───────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_WITH_RANDOM_32_BYTES"
AUTH_TRUST_HOST=true

# Application URLs
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── M-PESA (Safaricom Daraja) ─────────────────────────────────────
# Sandbox credentials from https://developer.safaricom.co.ke
MPESA_ENVIRONMENT="sandbox"       # or "production"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""                # Paybill or Till number
MPESA_CALLBACK_URL="https://your-domain.com/api/mpesa/callback"

# ─── SMS (Africa's Talking) ────────────────────────────────────────
AT_USERNAME="sandbox"             # or production username
AT_API_KEY=""
AT_SENDER_ID="LERATO"

# ─── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Lerato Platform <noreply@leratofoundation.org>"

# ─── File storage (Cloudflare R2 — S3-compatible) ─────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="lerato-uploads"
R2_PUBLIC_URL="https://uploads.leratofoundation.org"

# ─── Observability ─────────────────────────────────────────────────
# Optional — Sentry for error tracking
SENTRY_DSN=""

# ─── Feature flags ─────────────────────────────────────────────────
ENABLE_MPESA_GATEWAY="false"
ENABLE_WHATSAPP="false"
ENABLE_PUBLIC_DONOR_PORTAL="false"
