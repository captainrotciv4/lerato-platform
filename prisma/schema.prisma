// ════════════════════════════════════════════════════════════════════
// FUND ALLOCATIONS & APPROVALS
// ════════════════════════════════════════════════════════════════════
//
// FundAllocation represents a movement of funds:
//   - between organizations (e.g. Lerato → Darajani)
//   - between programmes within an organization
//   - from the main pool to a specific project
//
// Approvals are stacked: based on amount thresholds, 1-3 approvers must
// sign off before the allocation can be executed (which creates the
// matching Transaction records in both source and destination).

model FundAllocation {
  id              String   @id @default(cuid())

  // Origin and destination
  sourceOrgId     String                               // org the money leaves
  sourceOrg       Organization @relation("AllocationSource", fields: [sourceOrgId], references: [id])
  destinationOrgId String                              // org the money arrives at (may be same as source)
  destinationOrg  Organization @relation("AllocationDestination", fields: [destinationOrgId], references: [id])

  // Optional programme scoping
  sourceProgramId      String?
  sourceProgram        Program? @relation("AllocationSourceProgram", fields: [sourceProgramId], references: [id])
  destinationProgramId String?
  destinationProgram   Program? @relation("AllocationDestinationProgram", fields: [destinationProgramId], references: [id])

  // Money
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("KES")

  // Reason and metadata
  title           String                               // short description
  description     String?                              // longer context
  category        String?                              // e.g., "Equipment", "Travel", "Programme top-up"

  // Workflow
  status          AllocationStatus @default(DRAFT)
  requiredApprovers Int    @default(1)                 // calculated from rule at creation
  approvals       Approval[]

  // Lifecycle
  createdById     String
  createdAt       DateTime @default(now())
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  executedAt      DateTime?
  executedById    String?

  // Linked transactions (debit on source, credit on destination)
  sourceTransactionId      String?
  destinationTransactionId String?

  @@index([sourceOrgId])
  @@index([destinationOrgId])
  @@index([status])
  @@index([createdAt])
}

enum AllocationStatus {
  DRAFT                  // creator still editing
  PENDING_APPROVAL       // submitted, waiting on approver(s)
  APPROVED               // all approvals collected, ready to execute
  REJECTED               // an approver said no — terminal
  EXECUTED               // funds actually moved (transactions created)
  CANCELLED              // creator cancelled
}

model Approval {
  id              String   @id @default(cuid())
  allocationId    String
  allocation      FundAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  // Approver
  approverId      String                               // User ID
  approverRole    Role                                 // role at time of approval (snapshot)
  level           Int                                  // 1, 2, 3 — order in the stack

  // Decision
  decision        ApprovalDecision?                    // null = pending
  decidedAt       DateTime?
  notes           String?

  // Audit
  createdAt       DateTime @default(now())

  @@index([allocationId])
  @@index([approverId])
  @@index([decision])
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

// Defines how many approvals are needed at which threshold per org.
// Example seed: { thresholdKes: 0,      approvers: 1, role: FINANCE_LEAD }
//               { thresholdKes: 50000,  approvers: 2, role: ADMIN }
//               { thresholdKes: 250000, approvers: 3, role: BOARD_MEMBER }
model ApprovalRule {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgApprovalRules", fields: [organizationId], references: [id], onDelete: Cascade)

  thresholdAmount   Decimal  @db.Decimal(12, 2)
  currency          String   @default("KES")
  requiredApprovers Int
  requiredRoles     Role[]
  active            Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([thresholdAmount])
}

