// Lerato Platform — Database Schema
// Multi-organization management platform for Lerato Foundation, Darajani Sports Academy, and Agape in Action.
//
// Author: Victor Muoki <victor@victormuoki.com>
// Reference: VMK-Q-2026-0617
//
// Design principles:
//   1. Single database, shared schema, row-level isolation by organizationId
//   2. Every tenant-scoped model has organizationId FK and an index on it
//   3. Cross-org sharing via `sharedWith` join tables for Donor & Partner
//   4. Audit trail on every mutation via AuditLog
//   5. Soft deletes via deletedAt; never hard-delete beneficiary or financial data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ════════════════════════════════════════════════════════════════════
// ORGANIZATIONS & MULTI-TENANCY
// ════════════════════════════════════════════════════════════════════

model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique          // lerato, darajani, agape
  name        String                    // "Lerato Foundation"
  shortName   String                    // "Lerato"
  legalName   String?                   // Full legal name for compliance reports
  taxId       String?
  registrationNo String?
  type        OrgType                   // FOUNDATION, ACADEMY, MISSION

  // Branding
  logoUrl     String?
  primaryColor   String  @default("#ED1C24")
  secondaryColor String  @default("#231F20")
  accentColor    String?

  // Contact
  email       String?
  phone       String?
  whatsapp    String?
  website     String?
  address     String?
  county      String?
  country     String  @default("Kenya")

  // About
  description   String?                   // Public-facing org description
  launchDate    DateTime?                 // Official launch / founding date

  // Email / Communications
  emailFromName    String?               // Display name for outbound emails e.g. "Lerato Foundation"
  emailFromAddress String?               // From address override e.g. "no-reply@lerato.org"
  emailReplyTo     String?               // Reply-to address

  // Social media
  linkedinUrl   String?
  facebookUrl   String?
  instagramUrl  String?
  twitterUrl    String?

  // Relations
  memberships     Membership[]
  beneficiaries   Beneficiary[]
  staffVolunteers StaffVolunteer[]
  branches        Branch[]
  partnerships    Partnership[]          @relation("OrgPartnerships")
  events          Event[]
  transactions    Transaction[]
  programs        Program[]
  missions        Mission[]
  reports         Report[]
  auditLogs       AuditLog[]
  sharedDonors    DonorShare[]

  // Fund allocations & approval rules
  allocationsFrom FundAllocation[] @relation("AllocationSource")
  allocationsTo   FundAllocation[] @relation("AllocationDestination")
  approvalRules   ApprovalRule[]   @relation("OrgApprovalRules")

  // Chart of accounts
  accounts        Account[]

  // Extended modules
  journalEntries  JournalEntry[]
  fixedAssets     FixedAsset[]
  budgets         Budget[]
  leaveRequests   LeaveRequest[]
  payrollRecords  PayrollRecord[]
  vendors         Vendor[]
  purchaseOrders  PurchaseOrder[]

  // Files
  documents       Document[]  @relation("OrgDocuments")
  mediaAssets     MediaAsset[] @relation("OrgMedia")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([slug])
}

enum OrgType {
  FOUNDATION   // Lerato
  ACADEMY      // Darajani
  MISSION      // Agape in Action
  OTHER
}

// ════════════════════════════════════════════════════════════════════
// USERS, ROLES & AUTH
// ════════════════════════════════════════════════════════════════════

model User {
  id              String   @id @default(cuid())
  email           String?  @unique
  emailVerified   DateTime?
  phone           String?  @unique
  phoneVerified   DateTime?
  name            String
  title           String?                 // job title e.g. "CEO", "Finance Officer"
  avatarUrl       String?
  hashedPassword  String?                 // null if passwordless
  active          Boolean  @default(true)

  // Cross-org memberships — a user can have different roles in different orgs
  memberships     Membership[]

  // Activity
  sessions            Session[]
  auditLogs           AuditLog[]              @relation("AuditActor")
  scoutReports        ScoutReport[]
  loginLogs           LoginLog[]
  passwordResetTokens PasswordResetToken[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime?
  deletedAt       DateTime?

  @@index([email])
  @@index([phone])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Membership {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role            Role
  permissions     String[]              // Override permissions beyond role default
  active          Boolean  @default(true)
  invitedById     String?
  joinedAt        DateTime @default(now())
  revokedAt       DateTime?

  // Optional branch scope — when set, this user only sees data for this branch
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([branchId])
}

enum Role {
  ADMIN
  PROGRAMME_MANAGER
  FINANCE
  FINANCE_LEAD              // senior finance — can approve mid-tier allocations
  COMMUNICATIONS
  FIELD_STAFF
  BOARD_OBSERVER            // read-only board visibility
  BOARD_MEMBER              // can approve high-tier allocations
}

// ════════════════════════════════════════════════════════════════════
// PEOPLE — BENEFICIARIES (students, players, programme participants)
// ════════════════════════════════════════════════════════════════════

model Beneficiary {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  // Identity
  admissionNo     String?              // auto-generated on registration: DAR26-0001
  firstName       String
  middleName      String?
  lastName        String
  dateOfBirth     DateTime
  gender          Gender
  nationalId      String?
  birthCertNo     String?

  // Contact
  phone           String?
  email           String?
  address         String?
  county          String?
  guardianName    String?
  guardianPhone   String?
  guardianEmail   String?
  guardianRelationship String?           // Mother, Father, Uncle, Legal Guardian…

  // Programme links
  enrolments      ProgramEnrolment[]

  // Athlete-specific (for Darajani — nullable for non-athletes)
  athleteProfile  AthleteProfile?

  // Student-specific
  studentProfile  StudentProfile?

  // Scouting
  scoutReports    ScoutReport[]

  // Records
  attendances         Attendance[]
  trainingAttendances TrainingAttendance[]
  outcomes            Outcome[]
  surveyResponses     SurveyResponse[]
  documents           Document[]      @relation("BeneficiaryDocuments")

  // Branch assignment (Darajani)
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])

  // Soft delete + audit
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@unique([organizationId, admissionNo])
  @@unique([organizationId, nationalId])
  @@unique([organizationId, birthCertNo])
  @@index([organizationId])
  @@index([lastName, firstName])
  @@index([nationalId])
  @@index([branchId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// Athlete-specific — FIFA/FKF compliance
model AthleteProfile {
  id                  String   @id @default(cuid())
  beneficiaryId       String   @unique
  beneficiary         Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  jerseyNumber        Int?
  position            String?              // GK, CB, CM, ST, etc.
  preferredFoot       String?              // LEFT, RIGHT, BOTH
  heightCm            Float?
  weightKg            Float?
  // FIFA compliance fields
  fifaPlayerId        String?  @unique
  fkfRegistrationNo   String?  @unique
  passportNo          String?
  registeredAt        DateTime?
  registrationStatus  String?
  // Performance
  matchesPlayed       Int      @default(0)
  goals               Int      @default(0)
  assists             Int      @default(0)
  cleanSheets         Int      @default(0)
  yellowCards         Int      @default(0)
  redCards            Int      @default(0)

  // Player database fields
  currentClub         String?              // other club the player trains with
  playingStrengths    String?              // free-text strengths narrative
  areasToImprove      String?              // free-text development areas
  characterNotes      String?              // discipline, attitude, teamwork

  @@index([fifaPlayerId])
  @@index([fkfRegistrationNo])
}

// Student-specific
model StudentProfile {
  id              String   @id @default(cuid())
  beneficiaryId   String   @unique
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  school          String?
  grade           String?
  scholarshipType String?
  enrolledAt      DateTime?
  graduatedAt     DateTime?
  academicScore   Float?
  academicNotes   String?              // narrative on academic performance
  notes           String?
}

// Scout reports — one per scouting session per player
model ScoutReport {
  id              String      @id @default(cuid())
  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  scoutId         String?
  scout           User?       @relation(fields: [scoutId], references: [id])
  reportDate      DateTime    @default(now())
  recommendation  String      // SIGN, MONITOR, DECLINE, REVIEW_LATER
  strengths       String?
  areasToImprove  String?
  characterNotes  String?
  academicNotes   String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([beneficiaryId])
  @@index([scoutId])
  @@index([reportDate])
}

// ════════════════════════════════════════════════════════════════════
// PEOPLE — DONORS
// ════════════════════════════════════════════════════════════════════

model Donor {
  id              String   @id @default(cuid())
  type            DonorType

  // Identity
  firstName       String?
  lastName        String?
  organizationName String?            // for institutional donors
  email           String?
  phone           String?
  whatsapp        String?
  address         String?
  country         String   @default("Kenya")

  // Profile
  tier            DonorTier @default(BRONZE)
  taxExempt       Boolean  @default(false)
  taxId           String?
  commPreferences String[]            // ["email", "sms", "whatsapp"]
  notes           String?

  // Cross-org: which orgs is this donor associated with
  sharedWith      DonorShare[]

  // Giving
  donations       Donation[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([email])
  @@index([lastName, firstName])
}

enum DonorType {
  INDIVIDUAL
  ORGANIZATION
  ANONYMOUS
}

enum DonorTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  PATRON
}

// Cross-org donor sharing — a donor can give to multiple orgs
model DonorShare {
  id              String   @id @default(cuid())
  donorId         String
  donor           Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  relationshipNote String?
  addedAt         DateTime @default(now())

  @@unique([donorId, organizationId])
  @@index([organizationId])
}

model Donation {
  id              String   @id @default(cuid())
  donorId         String
  donor           Donor    @relation(fields: [donorId], references: [id])
  organizationId  String                              // which org received the donation
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("KES")
  channel         DonationChannel
  reference       String?                             // M-PESA receipt, bank ref, etc.
  designatedFor   String?                             // programme it was earmarked for
  programId       String?
  receivedAt      DateTime @default(now())
  acknowledgedAt  DateTime?
  receiptIssued   Boolean  @default(false)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([donorId])
  @@index([organizationId])
  @@index([receivedAt])
}

enum DonationChannel {
  MPESA
  BANK_TRANSFER
  CASH
  CHEQUE
  CARD
  CRYPTO
  OTHER
}

// ════════════════════════════════════════════════════════════════════
// PEOPLE — STAFF & VOLUNTEERS
// ════════════════════════════════════════════════════════════════════

model StaffVolunteer {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  firstName       String
  lastName        String
  email           String?
  phone           String?
  type            StaffType
  position        String?
  department      String?
  startDate       DateTime?
  endDate         DateTime?
  active          Boolean  @default(true)

  // Certifications
  certifications  String[]
  notes           String?

  // HR relations
  leaveRequests   LeaveRequest[]
  payrollRecords  PayrollRecord[]

  // Branch assignment (Darajani)
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([organizationId])
  @@index([branchId])
}

enum StaffType {
  EMPLOYEE
  VOLUNTEER
  COACH
  MENTOR
  INTERN
  CONSULTANT
}

// ════════════════════════════════════════════════════════════════════
// PEOPLE — PARTNERS
// ════════════════════════════════════════════════════════════════════

model Partnership {
  id              String   @id @default(cuid())
  organizationId  String                            // the org that owns this partnership
  organization    Organization @relation("OrgPartnerships", fields: [organizationId], references: [id])

  partnerName     String                            // "Agape in Action", "Christian Family"
  partnerType     PartnerType
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  website         String?
  description     String?
  active          Boolean  @default(true)
  startDate       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([organizationId])
}

enum PartnerType {
  STRATEGIC
  COMMUNITY
  SUPPORTING
  OTHER
}

// ════════════════════════════════════════════════════════════════════
// BRANCHES — training/operational locations within an org (Darajani)
// ════════════════════════════════════════════════════════════════════

model Branch {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String                    // "Darajani Elite"
  slug            String                    // "darajani-elite"
  description     String?
  location        String?                   // "Mwiki, Nairobi Kasarani"
  county          String?
  isMain          Boolean  @default(false)
  active          Boolean  @default(true)

  // Branch-level branding (overrides org theme on branch pages)
  primaryColor    String   @default("#16A34A")
  accentColor     String   @default("#FACC15")

  // Members of this branch
  beneficiaries   Beneficiary[]
  staff           StaffVolunteer[]
  sessions        TrainingSession[]
  memberships     Membership[]
  mediaAssets     MediaAsset[]     @relation("BranchMedia")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

// ════════════════════════════════════════════════════════════════════
// TRAINING SESSIONS & ROLLCALL (Darajani branches)
// ════════════════════════════════════════════════════════════════════

model TrainingSession {
  id            String   @id @default(cuid())
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  date          DateTime
  sessionType   String   @default("TRAINING")  // TRAINING | MATCH | FITNESS | CAMP | ASSESSMENT
  notes         String?
  capturedById  String?

  createdAt     DateTime @default(now())

  attendances   TrainingAttendance[]

  @@index([branchId])
  @@index([date])
}

model TrainingAttendance {
  id            String   @id @default(cuid())
  sessionId     String
  session       TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id])

  present       Boolean  @default(true)
  notes         String?

  @@unique([sessionId, beneficiaryId])
  @@index([sessionId])
  @@index([beneficiaryId])
}

// ════════════════════════════════════════════════════════════════════
// PROGRAMS
// ════════════════════════════════════════════════════════════════════

model Program {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  type            ProgramType
  name            String
  description     String?
  status          ProgramStatus @default(ACTIVE)
  startDate       DateTime?
  endDate         DateTime?

  // Enrolments
  enrolments      ProgramEnrolment[]

  // Outcomes
  outcomes        Outcome[]

  // Fund allocations into / out of this programme
  allocationsFrom FundAllocation[] @relation("AllocationSourceProgram")
  allocationsTo   FundAllocation[] @relation("AllocationDestinationProgram")

  mediaAssets     MediaAsset[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([organizationId])
  @@index([type])
}

enum ProgramType {
  EDUCATION
  LIFE_PROGRAM       // A Meal A Day, Clean Water
  SPORTS_DARAJANI
  SPORTS_OUTREACH    // Lerato sports outreach (non-academy)
  MENTORSHIP
  COMMUNITY_DEV
  AGAPE_MISSION
  OTHER
}

enum ProgramStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model ProgramEnrolment {
  id              String   @id @default(cuid())
  programId       String
  program         Program  @relation(fields: [programId], references: [id])
  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id])
  enrolledAt      DateTime @default(now())
  exitedAt        DateTime?
  status          String   @default("ACTIVE")
  notes           String?

  attendances     Attendance[]

  @@unique([programId, beneficiaryId])
  @@index([programId])
  @@index([beneficiaryId])
}

model Attendance {
  id              String   @id @default(cuid())
  enrolmentId     String
  enrolment       ProgramEnrolment @relation(fields: [enrolmentId], references: [id])
  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id])
  date            DateTime
  present         Boolean
  notes           String?
  capturedBy      String?              // staff/volunteer user ID
  syncedAt        DateTime @default(now())  // for offline-first mobile

  @@index([enrolmentId])
  @@index([beneficiaryId])
  @@index([date])
}

// ════════════════════════════════════════════════════════════════════
// AGAPE — MISSIONS (international trips, delegations, visa logistics)
// ════════════════════════════════════════════════════════════════════

model Mission {
  id              String   @id @default(cuid())
  organizationId  String                            // typically Agape
  organization    Organization @relation(fields: [organizationId], references: [id])

  name            String                            // "World Cup Engagement Programme 2026"
  type            MissionType
  destination     String                            // "Senegal, Nigeria"
  countries       String[]
  departureDate   DateTime?
  returnDate      DateTime?
  status          MissionStatus @default(PLANNING)
  description     String?
  budget          Decimal? @db.Decimal(12, 2)

  delegates       MissionDelegate[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum MissionType {
  EVANGELISM
  HUMANITARIAN
  ENGAGEMENT_PROGRAMME      // e.g. World Cup Engagement
  CAPACITY_BUILDING
  PARTNERSHIP_VISIT
  OTHER
}

enum MissionStatus {
  PLANNING
  VISA_PROCESSING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

model MissionDelegate {
  id              String   @id @default(cuid())
  missionId       String
  mission         Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // Delegate identity (could be staff, volunteer, or beneficiary)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  role            String?                           // "Delegation Lead", "Accompanying"

  // Travel documents
  passportNo      String?
  passportExpiry  DateTime?
  passportImageUrl String?
  visaStatus      VisaStatus @default(NOT_STARTED)
  visaIssuedAt    DateTime?
  ticketRef       String?

  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([missionId])
}

enum VisaStatus {
  NOT_STARTED
  APPLIED
  PROCESSING
  APPROVED
  REJECTED
  EXEMPT          // for visa-free destinations
}

// ════════════════════════════════════════════════════════════════════
// OPERATIONS — EVENTS, FINANCE, COMMUNICATION
// ════════════════════════════════════════════════════════════════════

model Event {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  name            String
  type            EventType
  description     String?
  venue           String?
  startsAt        DateTime
  endsAt          DateTime?
  status          EventStatus @default(SCHEDULED)
  registrationOpen Boolean @default(false)
  capacity        Int?

  mediaAssets     MediaAsset[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([organizationId])
  @@index([startsAt])
}

enum EventType {
  TOURNAMENT
  FUNDRAISER
  TRAINING_CAMP
  MISSION_DEPARTURE
  COMMUNITY_DAY
  BOARD_MEETING
  OTHER
}

enum EventStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

model Transaction {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  type            TxType
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("KES")
  description     String
  category        String?
  reference       String?                           // M-PESA receipt, cheque #, etc.
  occurredAt      DateTime
  reconciledAt    DateTime?
  reconciledById  String?

  approvalStatus  String   @default("POSTED")       // POSTED | PENDING_APPROVAL | REJECTED
  createdById     String?

  donationId      String?

  // Account routing — double-entry
  fromAccountId   String?
  fromAccount     Account?  @relation("TxFromAccount", fields: [fromAccountId], references: [id])
  toAccountId     String?
  toAccount       Account?  @relation("TxToAccount", fields: [toAccountId], references: [id])

  // Extra context
  payee           String?   // for EXPENSE: who was paid
  budgetLine      String?   // e.g., "5020-TRAVEL"
  tags            String[]  @default([])

  // Journal entry (auto-created on post)
  journalEntry    JournalEntry?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([occurredAt])
  @@index([approvalStatus])
  @@index([fromAccountId])
  @@index([toAccountId])
}

enum TxType {
  INCOME
  EXPENSE
  TRANSFER
}

// ════════════════════════════════════════════════════════════════════
// CHART OF ACCOUNTS
// ════════════════════════════════════════════════════════════════════
//
// Combines NGO fund accounting with institutional double-entry principles.
// ASSET / LIABILITY / EQUITY are balance-sheet accounts (track balances).
// INCOME / EXPENSE are P&L accounts (measure flows over a period).
//
// Code ranges:   1000-1999 = Assets   2000-2999 = Liabilities
//                3000-3999 = Equity   4000-4999 = Income   5000-5999 = Expense

model Account {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  code           String      // e.g., "1010"
  name           String      // e.g., "M-PESA Float"
  type           AccountType
  subtype        String?     // CASH | BANK | MPESA | RECEIVABLE | PAYABLE | RESTRICTED | UNRESTRICTED
  description    String?
  currency       String      @default("KES")

  // Running balance — updated when transactions are posted
  // For ASSET: positive = funds available
  // For LIABILITY: positive = amount owed
  // For INCOME/EXPENSE: tracks period total (reset per financial year)
  balance        Decimal     @default(0) @db.Decimal(14, 2)

  // Account tree (sub-accounts, e.g. "1020 Equity Bank" under "1000 Cash & Equivalents")
  parentId       String?
  parent         Account?    @relation("AccountTree", fields: [parentId], references: [id])
  children       Account[]   @relation("AccountTree")

  // NGO-specific flags
  isRestricted   Boolean     @default(false)  // donor-restricted fund
  restrictionNote String?                     // e.g., "Agape WC2026 Travel Fund"
  isSystem       Boolean     @default(false)  // seeded — cannot delete
  active         Boolean     @default(true)

  // Linked transactions
  outgoingTx     Transaction[] @relation("TxFromAccount")
  incomingTx     Transaction[] @relation("TxToAccount")
  journalLines   JournalLine[]
  budgets        Budget[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([type])
  @@index([active])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

